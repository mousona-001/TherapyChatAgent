# Environment Variables — API Service (apps/api)
# Copy this to .env and fill in the values

PORT=3001

# Groq AI (LLM for therapist chat agent)
GROQ_API_KEY=your_groq_api_key_here

# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://postgres:password@localhost:5432/therapychat"

# Better Auth
BETTER_AUTH_SECRET="generate-a-long-random-string-here"
BETTER_AUTH_URL="http://localhost:3001"

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twilio (outbound crisis calls + SMS fallback)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ElevenLabs (initial crisis audio generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Public URLs (use ngrok tunnels in development)
API_BASE_URL=https://your-api.ngrok.io         # this service — port 3001
STREAM_BASE_URL=https://your-stream.ngrok.io   # apps/stream — port 3002

# Redis (shared session state with apps/stream)
REDIS_URL=redis://localhost:6379
