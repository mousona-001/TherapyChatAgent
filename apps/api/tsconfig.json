{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "ignoreDeprecations": "5.0",
    "types": ["node"],
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "node_modules/@repo/types/src",
    "node_modules/@repo/types/node_modules",
    "node_modules/@repo/typescript-config"
  ]
}


