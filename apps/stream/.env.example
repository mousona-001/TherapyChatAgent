# Environment Variables — Crisis Stream Microservice
# Copy this to .env and fill in the values

# Port this WebSocket server listens on
STREAM_PORT=3002

# Groq AI (LLM for crisis agent responses)
GROQ_API_KEY=your_groq_api_key_here

# Deepgram (real-time speech-to-text)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs (streaming text-to-speech, ulaw_8000 output for Twilio)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# Redis (shared session state with apps/api)
REDIS_URL=redis://localhost:6379
